# ========================================
# SocialFlow - Environment Variables
# ========================================
# This file documents all environment variables used in the project
# For local development: copy to apps/web/.env.local and fill in values
# For Vercel: add variables in project Settings → Environment Variables

# ========================================
# Application Settings
# ========================================

# Application environment (development, staging, production)
ENVIRONMENT=development

# Public app URL (used in emails, OAuth redirects, etc)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Staging: https://staging.socialflow.com
# Production: https://socialflow.com

# ========================================
# Database (PostgreSQL)
# ========================================

# Connection string for PostgreSQL
# Local format: postgresql://user:password@localhost:5432/dbname
# Vercel Postgres: Get from Vercel dashboard
DATABASE_URL=postgresql://user:password@localhost:5432/socialflow

# ========================================
# Redis (Caching & Sessions)
# ========================================

# Redis connection URL
# Local: redis://localhost:6379
# Vercel Redis: Get from Vercel dashboard
REDIS_URL=redis://localhost:6379

# ========================================
# Authentication
# ========================================

# Better Auth secret (must be at least 32 characters)
# Generate: openssl rand -hex 32
BETTER_AUTH_SECRET=your-secret-key-min-256-bits-here

# JWT secret for token signing
# Generate: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-key-min-256-bits-here

# ========================================
# OAuth Providers (for login/signup)
# ========================================

# Google OAuth
# Get from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft OAuth
# Get from: https://portal.azure.com/
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# ========================================
# Payment Processing - Stripe
# ========================================

# Stripe API keys
# Test: sk_test_* and pk_test_*
# Live: sk_live_* and pk_live_*
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook signing secret
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ========================================
# Email Service - Resend
# ========================================

# Resend API key for sending emails
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Sender email address
RESEND_FROM_EMAIL=noreply@socialflow.com

# ========================================
# Monitoring & Analytics (Optional)
# ========================================

# Sentry error tracking
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Analytics service
# ANALYTICS_ID=G-XXXXXXXXXX

# ========================================
# Turbo Cache (for Vercel deployments)
# ========================================

# Vercel Turbo token for remote caching
# Get from: https://vercel.com/account/tokens
# TURBO_TOKEN=your-vercel-token

# Vercel team slug for Turbo
# TURBO_TEAM=your-team-slug

# ========================================
# Three-Environment Summary
# ========================================
#
# DEVELOPMENT (local):
#   - ENVIRONMENT=development
#   - NEXT_PUBLIC_APP_URL=http://localhost:3000
#   - Use test/sandbox API keys
#   - Local PostgreSQL and Redis
#
# STAGING (main branch):
#   - ENVIRONMENT=staging
#   - NEXT_PUBLIC_APP_URL=https://staging.socialflow.com
#   - Use test/sandbox API keys
#   - Vercel Postgres and Redis
#
# PRODUCTION (prod branch):
#   - ENVIRONMENT=production
#   - NEXT_PUBLIC_APP_URL=https://socialflow.com
#   - Use LIVE API keys
#   - Vercel Postgres and Redis
