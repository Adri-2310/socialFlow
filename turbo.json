{
  "$schema": "https://turbo.build/json-schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "outputs": [],
      "cache": true
    },
    "test:coverage": {
      "outputs": ["coverage/**"],
      "cache": true
    },
    "type-check": {
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  },
  "globalDependencies": ["**/.env.local", "**/.env"]
}
