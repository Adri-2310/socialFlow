{
  "buildCommand": "turbo run build --filter=@socialflow/web",
  "installCommand": "pnpm install",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "nodejs": "20.x",
  "env": {
    "TURBO_TOKEN": "@TURBO_TOKEN",
    "TURBO_TEAM": "@TURBO_TEAM"
  },
  "git": {
    "deploymentEnabled": {
      "main": true,
      "dev": true,
      "prod": true
    }
  }
}
