# ========================================
# SocialFlow - Variables d'environnement
# ========================================
# Documente toutes les variables utilisees par le projet. Aucune valeur reelle
# ici, seulement des exemples - ce fichier est le seul commite sur GitHub.
#
# En local : copier vers apps/web/.env.local et remplir les vraies valeurs.
#   Si la base Neon est deja provisionnee sur Vercel, plus simple de recuperer
#   directement les vraies valeurs avec :
#     npx vercel env pull apps/web/.env.local
#
# Sur Vercel : les vraies valeurs vivent dans Project Settings -> Environment
#   Variables, scopees par environnement (Development / Preview / Production).
#   Preview = branche dev + branches feature/*, Production = branche main.

# ========================================
# Application
# ========================================

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ========================================
# Base de donnees (PostgreSQL via Neon)
# ========================================
# Provisionnee automatiquement par l'integration Vercel Marketplace "Neon".
# DATABASE_URL          = connexion "pooled", utilisee par l'app au runtime
# DATABASE_URL_UNPOOLED = connexion directe, utilisee par Prisma pour les migrations
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host/dbname?sslmode=require

# ========================================
# Authentification - Better Auth
# ========================================
# Generer une cle securisee (min 256 bits) : openssl rand -hex 32
BETTER_AUTH_SECRET=your-secret-key-min-256-bits-here

# OAuth Google - console.cloud.google.com -> APIs & Services -> Credentials
# Redirect URI a declarer : {NEXT_PUBLIC_APP_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth Microsoft - portal.azure.com -> Microsoft Entra ID -> App registrations
# Redirect URI a declarer : {NEXT_PUBLIC_APP_URL}/api/auth/callback/microsoft
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# ========================================
# A venir (non integre pour l'instant)
# ========================================

